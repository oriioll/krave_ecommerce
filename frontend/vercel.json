{
    "rewrites": [
        {
            "source": "/docs",
            "destination": "https://krave-ecommerce-docs.vercel.app"
        },
        {
            "source": "/docs/:path*",
            "destination": "https://krave-ecommerce-docs.vercel.app/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}